# Kairos OS Full-Stack Docker environment example

# Environment mode (development, production, test)
APP_ENV=development

# API Configuration
APP_NAME="Kairos API"
APP_VERSION=2.1.0
API_V1_PREFIX=/api/v1
CREATE_TABLES_ON_STARTUP=true
USE_MOCK_DATA=false

# Plugins configuration
KAIROS_PLUGINS_ENABLED=true
KAIROS_PLUGINS_DIR=data/plugins

# Connectors configuration
KAIROS_CONNECTORS_ENABLED=true
KAIROS_CONNECTORS_DIR=data/connectors

# AI Runtime configuration (v2.1.0 — metadata only, no LLM calls in this release)
KAIROS_AI_ENABLED=true
KAIROS_AI_PROVIDER=ollama
# Set model name if you want it surfaced in capabilities (e.g. llama3.2, mistral)
KAIROS_AI_MODEL=
# Set base URL only if Ollama is on a non-default address
KAIROS_AI_BASE_URL=
KAIROS_AI_PLANNING_ENABLED=true
KAIROS_AI_DRY_RUN_ENABLED=true
KAIROS_AI_MAX_CONTEXT_COMMANDS=20
KAIROS_AI_MAX_CONTEXT_CONNECTORS=20
KAIROS_AI_MAX_CONTEXT_PLUGINS=20
# Keep false — execution is not implemented in v2.1. Planner hard-gates this regardless.
KAIROS_AI_EXECUTION_ENABLED=false

# Ollama Readiness
KAIROS_OLLAMA_READINESS_ENABLED=true
KAIROS_OLLAMA_BASE_URL=http://localhost:11434
KAIROS_OLLAMA_TAGS_PATH=/api/tags
KAIROS_OLLAMA_TIMEOUT_SECONDS=2

# Database storage path (defaults to SQLite if unset)
# DATABASE_URL=sqlite:////app/data/kairos-local.sqlite3

# Service ports
API_PORT=8000
DASHBOARD_PORT=3000

# CORS & Routing configurations
CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'
# ROOT_PATH=/api-subpath

# Security & Authentication (Required if APP_ENV=production)
# KAIROS_API_KEY=your-secure-local-api-key
# NEXT_PUBLIC_KAIROS_API_KEY=your-secure-local-api-key
