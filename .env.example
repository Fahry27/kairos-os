# Kairos OS local environment

# API application
APP_NAME=Kairos API
APP_VERSION=0.2.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CREATE_TABLES_ON_STARTUP=true

# Local service ports
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# PostgreSQL
POSTGRES_DB=kairos
POSTGRES_USER=kairos
POSTGRES_PASSWORD=kairos_dev_password
DATABASE_URL=postgresql+psycopg://kairos:kairos_dev_password@localhost:5432/kairos

# Redis
REDIS_URL=redis://localhost:6379

# API
API_URL=http://localhost:8000

# Dashboard reserved for future Next.js work
DASHBOARD_URL=http://localhost:3000
