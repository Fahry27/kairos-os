# Kairos OS local environment

# Project
KAIROS_ENV=development
KAIROS_APP_NAME=Kairos OS

# Local service ports
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL
POSTGRES_DB=kairos_dev
POSTGRES_USER=kairos
POSTGRES_PASSWORD=kairos_dev_password

# Redis
REDIS_URL=redis://localhost:6379

# Application URLs reserved for future services
API_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:5173
