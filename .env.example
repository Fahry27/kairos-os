# Kairos OS local environment

# API application
APP_NAME=Kairos API
APP_VERSION=0.3.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CREATE_TABLES_ON_STARTUP=true
USE_MOCK_DATA=false

# Local service ports
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# Local API storage
# DATABASE_URL defaults to the repository data/kairos-local.sqlite3 file.
# Override only when you need a custom local or remote database.
# DATABASE_URL=sqlite:///../../data/kairos-local.sqlite3

# PostgreSQL for Docker Compose services
POSTGRES_DB=kairos
POSTGRES_USER=kairos
POSTGRES_PASSWORD=kairos_dev_password

# Redis
REDIS_URL=redis://localhost:6379

# API
API_URL=http://localhost:8000

DASHBOARD_URL=http://localhost:3000

# Security & Authentication (Optional for local development, recommended for LAN deployment)
# KAIROS_API_KEY=your-secure-local-api-key
# NEXT_PUBLIC_KAIROS_API_KEY=your-secure-local-api-key
